/* ═══════════════════════════════════════════════════════════════
   CLOW v2.0 — Premium Cyberpunk Interface
   Inspired by canvas-design philosophy + claude-cookbooks aesthetics
   ═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

:root{
  --bg:#080b14;--bg2:#0c1020;--bg-sb:#0a0e1a;
  --glass:rgba(12,16,32,.7);--glass-bd:rgba(100,90,255,.1);--glass-hi:rgba(100,90,255,.06);
  --purple:#7c3aed;--indigo:#6366f1;--blue:#3b82f6;--cyan:#06b6d4;--violet:#8b5cf6;
  --pink:#c084fc;--magenta:#d946ef;--green:#22c55e;--amber:#f59e0b;--red:#ef4444;
  --t1:#eef2ff;--t2:#94a3b8;--t3:#64748b;--tm:#475569;
  --bd:rgba(99,102,241,.12);--bd2:rgba(99,102,241,.2);--bd3:rgba(99,102,241,.35);
  --sans:'Inter',system-ui,sans-serif;--mono:'JetBrains Mono',monospace;
  --sw:290px;--st:env(safe-area-inset-top,0px);--sab:env(safe-area-inset-bottom,0px);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{height:100%;overflow:hidden;position:fixed;width:100%}
input,textarea,select{font-size:16px!important}
body{background:var(--bg);color:var(--t1);font-family:var(--sans);font-size:14px;height:100dvh;height:100vh;display:flex;overflow:hidden;-webkit-font-smoothing:antialiased;position:relative;overscroll-behavior:none}

/* ── Ambient Background ─────────────────────────────────────── */
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 600px 400px at 50% 45%,rgba(99,102,241,.07),transparent),
    radial-gradient(ellipse 400px 300px at 30% 30%,rgba(124,58,237,.04),transparent),
    radial-gradient(ellipse 400px 300px at 70% 70%,rgba(59,130,246,.03),transparent)}

/* Scrollbar */
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(99,102,241,.2);border-radius:2px}

/* ═══ SIDEBAR ═══════════════════════════════════════════════ */
.sb{width:var(--sw);height:100%;background:var(--bg-sb);display:flex;flex-direction:column;flex-shrink:0;z-index:20;position:relative;border-right:1px solid var(--bd);transition:transform .3s cubic-bezier(.4,0,.2,1)}
.sb::after{content:'';position:absolute;right:-1px;top:0;width:1px;height:100%;background:linear-gradient(180deg,var(--purple) 0%,var(--blue) 40%,transparent 80%);opacity:.4}

.sb-head{padding:20px 16px 12px;padding-top:calc(16px + var(--st));display:flex;align-items:center;justify-content:center}
.sb-logo-img{height:52px;object-fit:contain;filter:drop-shadow(0 0 16px rgba(99,102,241,.3)) drop-shadow(0 0 32px rgba(59,130,246,.15));transition:filter .4s}
.sb-logo-img:hover{filter:drop-shadow(0 0 24px rgba(99,102,241,.5)) drop-shadow(0 0 48px rgba(59,130,246,.25))}

.sb-body{flex:1;overflow-y:auto;padding:0 14px 8px;display:flex;flex-direction:column;gap:2px}
.sb-sep{height:1px;background:linear-gradient(90deg,transparent,rgba(99,102,241,.12),transparent);margin:8px 0}

/* Section */
.sb-sec{margin-bottom:2px}
.sb-lbl{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);padding:10px 4px 4px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;user-select:none;transition:color .2s}
.sb-lbl:hover{color:var(--t2)}
.sb-lbl.lbl-cyan{color:var(--cyan)}.sb-lbl.lbl-cyan:hover{color:#67e8f9}
.sb-lbl.lbl-green{color:#34d399}.sb-lbl.lbl-green:hover{color:#6ee7b7}
.sb-lbl.lbl-amber{color:var(--amber)}.sb-lbl.lbl-amber:hover{color:#fcd34d}
.sb-lbl .ar{font-size:8px;opacity:.5;transition:transform .25s}.sb-lbl.open .ar{transform:rotate(90deg);opacity:.7}
.sb-ct{display:none;padding:2px 0 4px}.sb-lbl.open+.sb-ct{display:block}

/* ── "+ Nova Conversa" Button ───────────────────────────────── */
.sb-new{width:100%;padding:10px 0;border-radius:10px;border:none;background:linear-gradient(135deg,#7c3aed,#6366f1);color:#fff;font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;letter-spacing:.03em;transition:all .25s;box-shadow:0 4px 14px rgba(99,102,241,.35);margin-bottom:6px}
.sb-new:hover{background:linear-gradient(135deg,#8b5cf6,#818cf8);box-shadow:0 4px 20px rgba(99,102,241,.5);transform:translateY(-1px)}
.sb-new:active{transform:translateY(0);box-shadow:0 2px 8px rgba(99,102,241,.25)}

/* ── Sidebar Buttons (standard) ─────────────────────────────── */
.sb-btn{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:400;color:var(--t2);transition:all .2s;border:none;background:none;width:100%;text-align:left;font-family:var(--sans)}
.sb-btn:hover{background:var(--glass-hi);color:var(--t1)}
.sb-btn:active{transform:scale(.98)}
.sb-btn .ic{font-size:14px;width:20px;text-align:center;flex-shrink:0;opacity:.6}
.sb-btn:hover .ic{opacity:1}

/* ── CRIAR Items — 3D Crystal Orb Cards ─────────────────────── */
.sb-btn.criar{padding:9px 12px;border-radius:10px;background:var(--glass);border:1px solid var(--bd);font-weight:500;color:#c8d0e0;gap:10px;margin:2px 0}
.sb-btn.criar:hover{border-color:var(--bd2);background:rgba(99,102,241,.08);color:#fff;box-shadow:0 0 12px rgba(99,102,241,.08)}

/* Crystal Orb Icons */
.sb-orb{width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;position:relative;border:1px solid rgba(139,92,246,.25);transition:all .3s;
  background:radial-gradient(circle at 35% 30%,rgba(139,92,246,.55) 0%,rgba(99,102,241,.25) 50%,rgba(59,130,246,.15) 100%);
  box-shadow:0 0 10px rgba(99,102,241,.25),0 2px 6px rgba(0,0,0,.3),inset 0 1px 2px rgba(255,255,255,.12)}
.sb-orb::after{content:'';position:absolute;top:4px;left:6px;width:8px;height:5px;border-radius:50%;background:rgba(255,255,255,.18);transform:rotate(-20deg)}
.sb-orb.blue{background:radial-gradient(circle at 35% 30%,rgba(59,130,246,.6),rgba(6,182,212,.2));box-shadow:0 0 10px rgba(59,130,246,.25),0 2px 6px rgba(0,0,0,.3),inset 0 1px 2px rgba(255,255,255,.12);border-color:rgba(59,130,246,.25)}
.sb-orb.violet{background:radial-gradient(circle at 35% 30%,rgba(139,92,246,.6),rgba(124,58,237,.2));box-shadow:0 0 10px rgba(139,92,246,.25),0 2px 6px rgba(0,0,0,.3),inset 0 1px 2px rgba(255,255,255,.12);border-color:rgba(139,92,246,.25)}
.sb-orb.cyan{background:radial-gradient(circle at 35% 30%,rgba(6,182,212,.6),rgba(34,211,238,.2));box-shadow:0 0 10px rgba(6,182,212,.25),0 2px 6px rgba(0,0,0,.3),inset 0 1px 2px rgba(255,255,255,.12);border-color:rgba(6,182,212,.25)}
.sb-orb.pink{background:radial-gradient(circle at 35% 30%,rgba(192,132,252,.6),rgba(217,70,239,.2));box-shadow:0 0 10px rgba(192,132,252,.25),0 2px 6px rgba(0,0,0,.3),inset 0 1px 2px rgba(255,255,255,.12);border-color:rgba(192,132,252,.25)}
.sb-btn.criar:hover .sb-orb{box-shadow:0 0 18px rgba(99,102,241,.4),0 2px 8px rgba(0,0,0,.3),inset 0 1px 3px rgba(255,255,255,.15);transform:scale(1.08)}

/* ── Conversations ──────────────────────────────────────────── */
.sb-convs{flex:1;overflow-y:auto}
.sb-conv-search{padding:0 0 8px;position:relative}
.sb-conv-search input{width:100%;background:rgba(12,16,32,.8);border:1px solid var(--bd);border-radius:8px;padding:7px 10px 7px 28px;color:var(--t1);font-size:12px;font-family:var(--sans);outline:none;transition:all .2s}
.sb-conv-search input:focus{border-color:var(--bd2);box-shadow:0 0 8px rgba(99,102,241,.1)}
.sb-conv-search input::placeholder{color:var(--tm)}
.sb-conv-search .search-icon{position:absolute;left:8px;top:8px;font-size:11px;color:var(--t3);pointer-events:none}
.sb-grp-label{padding:6px 0 3px;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--t3)}
.sb-conv-item{display:flex;align-items:center;padding:7px 10px;border-radius:8px;cursor:pointer;transition:all .15s;gap:7px;margin:1px 0;min-height:38px}
.sb-conv-item:hover{background:var(--glass-hi)}
.sb-conv-item.act{background:rgba(99,102,241,.1);border-left:2px solid var(--indigo);padding-left:8px}
.sb-conv-item .conv-icon{font-size:12px;color:var(--t3);width:16px;text-align:center;flex-shrink:0}
.sb-conv-item.act .conv-icon{color:var(--violet)}
.sb-conv-item .conv-title{flex:1;font-size:13px;color:var(--t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;transition:color .15s}
.sb-conv-item.act .conv-title,.sb-conv-item:hover .conv-title{color:var(--t1)}
.sb-conv-item .conv-pin-static{font-size:9px;color:var(--tm);flex-shrink:0}
.sb-conv-item .conv-actions{display:flex;gap:2px;opacity:0;transition:opacity .15s}.sb-conv-item:hover .conv-actions{opacity:1}
.sb-conv-item .conv-actions .ca-btn{background:none;border:none;cursor:pointer;padding:2px 4px;border-radius:4px;font-size:11px;color:var(--t3);transition:all .1s;line-height:1}
.sb-conv-item .conv-actions .ca-btn:hover{background:rgba(99,102,241,.1);color:var(--t1)}

/* Context menu */
.conv-ctx-menu{position:fixed;background:rgba(12,16,30,.97);border:1px solid var(--bd);border-radius:10px;padding:4px;min-width:170px;z-index:50;box-shadow:0 8px 28px rgba(0,0,0,.6);animation:ctxIn .12s ease}
@keyframes ctxIn{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:scale(1)}}
.conv-ctx-menu .ctx-item{display:flex;align-items:center;gap:8px;padding:7px 12px;border-radius:7px;cursor:pointer;font-size:13px;color:var(--t2);font-family:var(--sans);transition:background .1s;border:none;background:none;width:100%;text-align:left}
.conv-ctx-menu .ctx-item:hover{background:var(--glass-hi);color:var(--t1)}
.conv-ctx-menu .ctx-item.danger{color:var(--red)}.conv-ctx-menu .ctx-item.danger:hover{background:rgba(239,68,68,.08)}
.conv-ctx-menu .ctx-item .ctx-icon{font-size:13px;width:16px;text-align:center;flex-shrink:0}

/* ── User Footer ────────────────────────────────────────────── */
.sb-foot{padding:10px 14px;padding-bottom:calc(10px + var(--sab));display:flex;align-items:center;gap:10px;border-top:1px solid var(--bd)}
.sb-av{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--purple),var(--blue));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;flex-shrink:0}
.sb-em{font-size:12px;color:var(--t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.sb-pl{font-size:9px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:3px 8px;border-radius:5px;background:linear-gradient(135deg,var(--purple),var(--magenta));color:#fff}

/* ═══ HEADER ════════════════════════════════════════════════ */
.hdr{height:46px;display:flex;align-items:center;padding:0 16px;background:rgba(8,11,20,.95);border-bottom:1px solid var(--bd);gap:10px;position:relative;z-index:30}
.hdr::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--purple),var(--indigo),var(--blue),var(--cyan));opacity:.7}
.ham{background:none;border:none;cursor:pointer;color:var(--t2);font-size:18px;padding:4px;border-radius:6px;display:none}
.ham:hover{color:var(--t1);background:var(--glass-hi)}
.hdr h2{font-size:14px;font-weight:500;color:var(--t1);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hdr-right{display:flex;align-items:center;gap:6px}
.on-badge{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--t3)}
.mod-pill{height:28px;padding:3px 10px;border-radius:7px;background:rgba(12,16,32,.8);border:1px solid var(--bd);color:var(--cyan);font-size:12px;font-weight:600;font-family:var(--sans);cursor:pointer;transition:all .2s}
.mod-pill:hover{border-color:var(--bd2)}.mod-pill.sonnet{color:var(--amber)}
.hdr-menu{position:relative}
.hdr-dots{width:28px;height:28px;border-radius:7px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.2);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--violet);font-size:14px;transition:all .15s}
.hdr-dots:hover{background:rgba(99,102,241,.2);border-color:rgba(99,102,241,.35)}
.hdr-drop{display:none;position:absolute;right:0;top:36px;width:240px;background:rgba(12,16,30,.97);border:1px solid var(--bd);border-radius:10px;padding:4px;box-shadow:0 8px 28px rgba(0,0,0,.6);z-index:50}
.hdr-drop.show{display:block}
.hdr-drop a,.hdr-drop button{display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:7px;font-size:13px;color:var(--t2);text-decoration:none;border:none;background:none;width:100%;text-align:left;font-family:var(--sans);cursor:pointer;transition:background .1s}
.hdr-drop a:hover,.hdr-drop button:hover{background:var(--glass-hi);color:var(--t1)}
.hdr-drop .sep{height:1px;background:var(--bd);margin:3px 8px}

/* ═══ MAIN AREA ═════════════════════════════════════════════ */
.main{flex:1;display:flex;flex-direction:column;min-width:0;position:relative;z-index:1}
.term{flex:1;overflow-y:auto;padding:20px;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}

/* ── Welcome Screen ─────────────────────────────────────────── */
.welc{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:40px 20px}
.welc-logo{height:80px;margin-bottom:20px;filter:drop-shadow(0 0 24px rgba(99,102,241,.25))}
.welc-tag{font-size:11px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--t3);margin-bottom:12px}
.welc-h{font-size:34px;font-weight:300;color:var(--t1)}
.welc-h em{font-style:italic;color:var(--violet);font-weight:400}
/* Decorative star flare */
.welc::after{content:'✦';position:absolute;bottom:18%;font-size:48px;color:rgba(99,102,241,.12);text-shadow:0 0 40px rgba(99,102,241,.2),0 0 80px rgba(59,130,246,.1);pointer-events:none;animation:starPulse 4s ease-in-out infinite}
@keyframes starPulse{0%,100%{opacity:.3;transform:scale(1)}50%{opacity:.6;transform:scale(1.1)}}
.qgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-width:460px;margin:24px auto 0}
@media(max-width:600px){.qgrid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:380px){.qgrid{grid-template-columns:1fr}}
.qcard{background:var(--glass);border:1px solid var(--bd);border-radius:10px;padding:12px;cursor:pointer;transition:all .2s;font-size:13px;color:var(--t2);font-family:var(--sans);text-align:left}
.qcard:hover{border-color:var(--bd2);color:var(--t1);box-shadow:0 0 8px rgba(99,102,241,.08);transform:translateY(-1px)}

/* ── Messages ───────────────────────────────────────────────── */
.ml{margin:0 auto;max-width:860px;width:100%;padding:3px 0;animation:msgIn .3s ease-out}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.ml.user{display:flex;justify-content:flex-end}
.ml.user .mb-wrap{background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.15);border-radius:14px 14px 4px 14px;padding:10px 14px;max-width:80%}
.ml.assistant .mb-wrap{max-width:100%;padding:10px 0}
.mh{display:flex;align-items:center;gap:5px;margin-bottom:3px;font-size:10px}
.mt{color:var(--t3)}.mn{font-weight:600;color:var(--t2)}
.mav{width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,var(--purple),var(--indigo));display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff}
.mb{color:var(--t1);font-size:14px;line-height:1.6}
.mb a{color:#60a5fa;text-decoration:underline}.mb strong{color:var(--t1);font-weight:600}
.mb code{background:rgba(6,8,18,.8);border:1px solid var(--bd);border-radius:4px;padding:1px 5px;font-family:var(--mono);font-size:13px}
.mb pre{background:rgba(6,8,18,.9);border:1px solid var(--bd);border-radius:10px;padding:14px;font-family:var(--mono);font-size:13px;overflow-x:auto;-webkit-overflow-scrolling:touch;margin:6px 0}
.mb h1,.mb h2,.mb h3{margin:10px 0 4px;color:var(--t1)}.mb h1{font-size:18px}.mb h2{font-size:16px}.mb h3{font-size:14px;color:#cbd5e1}
.mb ul,.mb ol{padding-left:18px;margin:4px 0}.mb li{margin:1px 0}.mb li::marker{color:var(--violet)}
.mb blockquote{border-left:2px solid var(--violet);background:rgba(99,102,241,.04);padding:6px 10px;margin:6px 0;border-radius:0 6px 6px 0}
.mb table{border-collapse:collapse;width:100%;margin:6px 0}.mb th,.mb td{border:1px solid var(--bd);padding:5px 8px;font-size:13px}.mb th{background:rgba(12,16,32,.8);font-weight:600}
.mb hr{border:none;height:1px;background:var(--bd);margin:10px 0}

/* Tool blocks */
.tblk{border-radius:8px;margin:4px 0;border:1px solid var(--bd);overflow:hidden;font-family:var(--mono);font-size:12px}
.tblk.act{border-color:rgba(99,102,241,.2)}.tblk.done{border-color:rgba(16,185,129,.2)}.tblk.err{border-color:rgba(239,68,68,.2)}
.thd{display:flex;align-items:center;gap:6px;padding:6px 10px;cursor:pointer;background:rgba(12,16,32,.5)}
.thd:hover{background:rgba(12,16,32,.7)}
.tdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.tblk.act .tdot{background:var(--indigo);box-shadow:0 0 6px rgba(99,102,241,.5);animation:dotPulse 2s ease-in-out infinite}
@keyframes dotPulse{0%,100%{box-shadow:0 0 4px rgba(99,102,241,.3)}50%{box-shadow:0 0 10px rgba(99,102,241,.6)}}
.tblk.done .tdot{background:#10b981}.tblk.err .tdot{background:var(--red)}
.tlb{flex:1;color:var(--t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.tn{color:var(--violet);font-weight:600}.ta{color:var(--t3)}
.tdr{color:var(--t3);font-size:10px;flex-shrink:0}
.tout{display:none;padding:6px 10px;background:rgba(6,8,18,.8);color:var(--t2);max-height:100px;overflow:auto;font-size:11px}.tblk.open .tout{display:block}
.tline{padding:1px 0;white-space:pre-wrap;word-break:break-all}.tmore{color:#60a5fa;cursor:pointer;padding:2px 0}

/* Thinking */
.think{padding:8px 0}.think-in{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--t2)}
.think-logo{width:18px;height:18px;background:linear-gradient(135deg,var(--purple),var(--indigo));border-radius:5px;animation:dotPulse 2s ease-in-out infinite}
.think-t{animation:thinkFade 1.2s ease-in-out infinite}@keyframes thinkFade{0%,100%{opacity:.4}50%{opacity:1}}
.eline{color:var(--red);font-size:13px;padding:3px 0}

/* File card */
.fcard{display:flex;align-items:center;gap:10px;background:var(--glass);border:1px solid var(--bd);border-radius:10px;padding:10px 14px;margin:6px 0}
.ficon{font-size:24px}.finfo{flex:1}.fname{font-size:13px;font-weight:500;color:var(--t1)}.fmeta{font-size:11px;color:var(--t3)}
.fbtn{padding:5px 12px;border-radius:7px;font-size:12px;font-weight:600;text-decoration:none;font-family:var(--sans);transition:all .15s;cursor:pointer;border:none}
.fbtn.pr{background:linear-gradient(135deg,var(--purple),var(--indigo));color:#fff;box-shadow:0 2px 10px rgba(99,102,241,.3)}.fbtn.pr:hover{box-shadow:0 4px 16px rgba(99,102,241,.45)}
.fbtn.sc{background:rgba(12,16,32,.8);color:var(--t2);border:1px solid var(--bd)}.fbtn.sc:hover{color:var(--t1)}

/* ═══ INPUT AREA ════════════════════════════════════════════ */
.input-area{flex-shrink:0;padding:10px 20px;padding-bottom:calc(10px + var(--sab));background:rgba(8,11,20,.95);border-top:1px solid rgba(99,102,241,.06);z-index:10}
.ibox{display:flex;align-items:flex-end;gap:6px;max-width:860px;margin:0 auto;background:rgba(12,16,32,.8);border:1px solid var(--bd);border-radius:14px;padding:10px 14px;transition:all .25s;box-shadow:0 0 10px rgba(99,102,241,.06),inset 0 1px 1px rgba(0,0,0,.2)}
.ibox:focus-within{border-color:var(--bd2);box-shadow:0 0 20px rgba(99,102,241,.12),inset 0 1px 1px rgba(0,0,0,.2)}
.ibox textarea{flex:1;background:transparent;border:none;color:var(--t1);font-family:var(--sans);font-size:15px;line-height:1.5;resize:none;outline:none;max-height:180px;min-height:22px}
.ibox textarea::placeholder{color:var(--tm)}
.ibox .ibtn,.ibox .send-btn{background:none;border:none;cursor:pointer;padding:4px;border-radius:6px;color:var(--t3);transition:all .15s;display:flex;align-items:center;justify-content:center}
.ibox .ibtn:hover,.ibox .send-btn:hover{color:var(--violet)}
.ibox .ibtn.recording{color:var(--red);animation:dotPulse 1s ease-in-out infinite}
.ibox-right{display:flex;align-items:center;gap:2px}

/* File/Audio previews */
.file-preview{padding:3px 0}
.audio-preview{display:flex;align-items:center;gap:6px;background:rgba(12,16,32,.8);border:1px solid var(--bd);border-radius:8px;padding:6px 10px}
.ap-play,.ca-play{background:none;border:none;cursor:pointer;color:var(--violet);font-size:14px;padding:2px}
.ap-bar,.ca-bar{flex:1;height:3px;background:rgba(12,16,32,.9);border-radius:2px;overflow:hidden}
.ap-fill,.ca-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--indigo));border-radius:2px;width:0}
.ap-dur,.ca-dur{font-size:10px;color:var(--t3);font-family:var(--mono)}
.ap-del{cursor:pointer;color:var(--t3);font-size:13px}.ap-del:hover{color:var(--red)}
.ap-transcript,.chat-transcription{font-size:11px;color:var(--t3);padding:3px 0;font-style:italic}
.chat-audio{display:flex;align-items:center;gap:6px;background:rgba(12,16,32,.8);border:1px solid var(--bd);border-radius:8px;padding:6px 10px;margin:3px 0}
.chat-img{max-width:280px;max-height:280px;border-radius:10px;cursor:pointer;transition:transform .2s}.chat-img:hover{transform:scale(1.02)}
.chat-file-card{display:flex;align-items:center;gap:6px;background:rgba(12,16,32,.8);border:1px solid var(--bd);border-radius:8px;padding:6px 10px;margin:3px 0}
.cfc-icon{font-size:18px}.cfc-name{font-size:12px;color:var(--t1);font-weight:500}.cfc-meta{font-size:10px;color:var(--t3)}
.attach-menu{position:absolute;bottom:100%;left:0;background:rgba(12,16,30,.97);border:1px solid var(--bd);border-radius:10px;padding:4px;box-shadow:0 8px 24px rgba(0,0,0,.5);z-index:50;min-width:180px}
.am-item{display:block;width:100%;padding:8px 12px;border:none;background:none;color:var(--t2);font-size:13px;font-family:var(--sans);cursor:pointer;border-radius:7px;text-align:left;transition:background .1s}
.am-item:hover{background:var(--glass-hi);color:var(--t1)}
.drag-ov{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:40;display:none;align-items:center;justify-content:center;font-size:16px;color:var(--violet)}.drag-ov.show{display:flex}
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:50;display:none;align-items:center;justify-content:center}.lightbox.show{display:flex}
.lightbox img{max-width:90%;max-height:90%;border-radius:8px}.lb-close{position:absolute;top:16px;right:16px;background:none;border:none;color:#fff;font-size:28px;cursor:pointer}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:40;display:none;align-items:center;justify-content:center}.modal-bg.show{display:flex}
.modal{background:rgba(12,16,30,.98);border:1px solid var(--bd);border-radius:16px;padding:20px;max-width:480px;width:90%;max-height:80vh;overflow-y:auto;box-shadow:0 16px 48px rgba(0,0,0,.6)}

/* ═══ RESPONSIVE ════════════════════════════════════════════ */
@media(max-width:768px){
  .sb{position:fixed;left:0;top:0;height:100%;transform:translateX(-100%);box-shadow:4px 0 20px rgba(0,0,0,.5);width:85vw;max-width:310px}
  .sb.open{transform:translateX(0)}
  .ham{display:block}
  .sb-ov{position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);z-index:15;display:none}.sb-ov.show{display:block}
  .qgrid{grid-template-columns:repeat(2,1fr)}
  .ml.user .mb-wrap{max-width:88%!important}
  .main{height:100dvh;overflow:hidden}
  .term{flex:1;overflow-y:auto;overscroll-behavior-y:contain}
  .input-area{flex-shrink:0;position:sticky;bottom:0;z-index:20;padding:8px 10px}
  body.kb-open .welc-h,body.kb-open .qgrid,body.kb-open .welc::after{display:none}
}
@media(max-width:480px){.welc-h{font-size:26px}.hdr h2{font-size:13px}}
@media(min-width:769px){.ham{display:none}}
@media(display-mode:standalone){body{padding-top:var(--st)}.hdr{padding-top:var(--st)}}

/* ═══ UTILITIES ═════════════════════════════════════════════ */
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
.stop-btn{position:absolute;width:36px;height:36px;border-radius:50%;border:none;cursor:pointer;display:none;align-items:center;justify-content:center;background:var(--red);color:#fff;transition:all .15s}.stop-btn.vis{display:flex}.stop-btn:hover{box-shadow:0 0 12px rgba(239,68,68,.3)}
.stop-btn svg{width:12px;height:12px}
.copy-toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:rgba(12,16,30,.95);color:var(--t1);padding:6px 16px;border-radius:16px;font-size:12px;z-index:60;opacity:0;transition:opacity .3s;pointer-events:none;border:1px solid var(--bd)}.copy-toast.show{opacity:1}
.pull-indicator{position:absolute;top:-50px;left:50%;transform:translateX(-50%);width:32px;height:32px;border-radius:50%;background:rgba(12,16,30,.9);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--t2);transition:top .2s,opacity .2s;opacity:0;z-index:5}
.pull-indicator.show{top:8px;opacity:1}
.pull-indicator.refreshing{animation:spin .8s linear infinite}
@keyframes spin{from{transform:translateX(-50%) rotate(0deg)}to{transform:translateX(-50%) rotate(360deg)}}
