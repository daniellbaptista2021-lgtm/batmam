{
  "name": "batmam",
  "displayName": "Batmam - AI Code Agent",
  "description": "Agente de código AI no VS Code. Inline edit, commit inteligente, code review, diff view, test generation e plan mode.",
  "version": "0.2.0",
  "publisher": "daniel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Machine Learning", "Other"],
  "keywords": ["ai", "agent", "code", "batmam", "assistant", "review", "test", "refactor"],
  "activationEvents": [
    "onCommand:batmam.open",
    "onCommand:batmam.ask",
    "onCommand:batmam.openInTerminal"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "batmam.open",
        "title": "Batmam: Abrir Painel",
        "icon": "$(hubot)"
      },
      {
        "command": "batmam.ask",
        "title": "Batmam: Perguntar",
        "icon": "$(comment)"
      },
      {
        "command": "batmam.openInTerminal",
        "title": "Batmam: Abrir no Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "batmam.explainSelection",
        "title": "Batmam: Explicar Seleção"
      },
      {
        "command": "batmam.fixSelection",
        "title": "Batmam: Corrigir Seleção"
      },
      {
        "command": "batmam.refactorSelection",
        "title": "Batmam: Refatorar Seleção"
      },
      {
        "command": "batmam.inlineEdit",
        "title": "Batmam: Edição Inline"
      },
      {
        "command": "batmam.commit",
        "title": "Batmam: Commit Inteligente"
      },
      {
        "command": "batmam.review",
        "title": "Batmam: Code Review"
      },
      {
        "command": "batmam.generateTests",
        "title": "Batmam: Gerar Testes"
      },
      {
        "command": "batmam.diffView",
        "title": "Batmam: Diff View"
      },
      {
        "command": "batmam.planMode",
        "title": "Batmam: Plan Mode"
      }
    ],
    "keybindings": [
      {
        "command": "batmam.open",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "batmam.ask",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "batmam.inlineEdit",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "batmam.commit",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "batmam.review",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "batmam.explainSelection",
          "when": "editorHasSelection",
          "group": "batmam@1"
        },
        {
          "command": "batmam.fixSelection",
          "when": "editorHasSelection",
          "group": "batmam@2"
        },
        {
          "command": "batmam.refactorSelection",
          "when": "editorHasSelection",
          "group": "batmam@3"
        },
        {
          "command": "batmam.inlineEdit",
          "when": "editorHasSelection",
          "group": "batmam@4"
        },
        {
          "command": "batmam.generateTests",
          "when": "editorHasSelection",
          "group": "batmam@5"
        }
      ]
    },
    "configuration": {
      "title": "Batmam",
      "properties": {
        "batmam.model": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "Modelo OpenAI a utilizar"
        },
        "batmam.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "Aprovar ferramentas automaticamente (cuidado!)"
        },
        "batmam.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Caminho para o Python do Batmam (auto-detectado)"
        },
        "batmam.planModeDefault": {
          "type": "boolean",
          "default": false,
          "description": "Iniciar em plan mode por padrão"
        }
      }
    }
  }
}
