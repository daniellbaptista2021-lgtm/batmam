{
  "name": "clow",
  "displayName": "Clow - AI Code Agent",
  "description": "Agente de código AI no VS Code. Inline edit, commit inteligente, code review, diff view, test generation e plan mode.",
  "version": "0.2.0",
  "publisher": "daniel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Machine Learning", "Other"],
  "keywords": ["ai", "agent", "code", "clow", "assistant", "review", "test", "refactor"],
  "activationEvents": [
    "onCommand:clow.open",
    "onCommand:clow.ask",
    "onCommand:clow.openInTerminal"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clow.open",
        "title": "Clow: Abrir Painel",
        "icon": "$(hubot)"
      },
      {
        "command": "clow.ask",
        "title": "Clow: Perguntar",
        "icon": "$(comment)"
      },
      {
        "command": "clow.openInTerminal",
        "title": "Clow: Abrir no Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "clow.explainSelection",
        "title": "Clow: Explicar Seleção"
      },
      {
        "command": "clow.fixSelection",
        "title": "Clow: Corrigir Seleção"
      },
      {
        "command": "clow.refactorSelection",
        "title": "Clow: Refatorar Seleção"
      },
      {
        "command": "clow.inlineEdit",
        "title": "Clow: Edição Inline"
      },
      {
        "command": "clow.commit",
        "title": "Clow: Commit Inteligente"
      },
      {
        "command": "clow.review",
        "title": "Clow: Code Review"
      },
      {
        "command": "clow.generateTests",
        "title": "Clow: Gerar Testes"
      },
      {
        "command": "clow.diffView",
        "title": "Clow: Diff View"
      },
      {
        "command": "clow.planMode",
        "title": "Clow: Plan Mode"
      }
    ],
    "keybindings": [
      {
        "command": "clow.open",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "clow.ask",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "clow.inlineEdit",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "clow.commit",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "clow.review",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "clow.explainSelection",
          "when": "editorHasSelection",
          "group": "clow@1"
        },
        {
          "command": "clow.fixSelection",
          "when": "editorHasSelection",
          "group": "clow@2"
        },
        {
          "command": "clow.refactorSelection",
          "when": "editorHasSelection",
          "group": "clow@3"
        },
        {
          "command": "clow.inlineEdit",
          "when": "editorHasSelection",
          "group": "clow@4"
        },
        {
          "command": "clow.generateTests",
          "when": "editorHasSelection",
          "group": "clow@5"
        }
      ]
    },
    "configuration": {
      "title": "Clow",
      "properties": {
        "clow.model": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "Modelo OpenAI a utilizar"
        },
        "clow.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "Aprovar ferramentas automaticamente (cuidado!)"
        },
        "clow.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Caminho para o Python do Clow (auto-detectado)"
        },
        "clow.planModeDefault": {
          "type": "boolean",
          "default": false,
          "description": "Iniciar em plan mode por padrão"
        }
      }
    }
  }
}
